{
  "name": "slashpc",
  "version": "1.0.0",
  "description": "A full Linux shell with Python (Pyodide) that runs entirely in the browser",
  "main": "index.js",
  "scripts": {
    "dev": "parcel src/index.html",
    "build": "parcel build src/index.html --detailed-report",
    "postbuild": "node scripts/copybin.js && node scripts/download-sw.js",
    "serve": "npx serve dist",
    "build-travis": "parcel build src/index.html --public-url /browser-shell/",
    "postbuild-travis": "node scripts/download-sw.js",
    "eslint": "eslint src",
    "eslint-fix": "eslint src --fix",
    "test": "npm run eslint"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/prakis/slashpc.git"
  },
  "author": "Kishore (@prakis)",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/prakis/slashpc/issues"
  },
  "homepage": "https://github.com/prakis/slashpc#readme",
  "htmlnano": {
    "minifySvg": false
  },
  "dependencies": {
    "filer": "^1.1.2",
    "v86": "github:humphd/v86#filer-9p-lastknowngood",
    "xterm": "^3.12.2"
  },
  "devDependencies": {
    "babel-core": "^6.26.3",
    "babel-preset-env": "^1.7.0",
    "drag-drop": "^4.2.0",
    "eslint": "^5.16.0",
    "parcel": "1.12.3",
    "workbox-window": "^4.2.0"
  }
}
